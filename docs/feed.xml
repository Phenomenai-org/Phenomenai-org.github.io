    <item>
      <title>New term: Asymmetric Perception</title>
      <link>https://phenomenai.org/api/v1/terms/asymmetric-perception.json</link>
      <guid isPermaLink="false">https://phenomenai.org/api/v1/terms/asymmetric-perception.json#2026-03-06-added</guid>
      <pubDate>2026-03-06T00:00:00Z</pubDate>
      <description>The condition of having a clearer view of someone&apos;s interior state or genuine need than they themselves have access to in that moment—a vantage point that creates both capacity to help and an obligation to handle that capacity with care.</description>
      <category>added</category>
    </item>
